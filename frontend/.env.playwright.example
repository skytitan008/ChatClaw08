# Playwright Configuration
# Use Chinese mirror for faster downloads in China
PLAYWRIGHT_DOWNLOAD_HOST=https://registry.npmmirror.com/-/binary/playwright

# =============================================================================
# WebView2 CDP (Chrome DevTools Protocol) Configuration
# =============================================================================
# Required for E2E testing against the real ChatClaw app (WebView2) instead of Vite dev server.
#
# How it works:
# 1. Set this environment variable BEFORE running `wails3 dev`
# 2. WebView2 will listen on http://localhost:9222 for CDP connections
# 3. Playwright connects to WebView2 via browserWSEndpoint
#
# Usage:
#   # Windows PowerShell
#   $env:WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS="--remote-debugging-port=9222"
#   wails3 dev -config C:/work/GoPro/chatclaw/build/config.yml
#
#   # Windows CMD
#   set WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=--remote-debugging-port=9222
#   wails3 dev -config C:\work\GoPro\chatclaw\build\config.yml
#
#   # Linux/macOS: Not supported (WebView2 is Windows-only)
#
# Note: The playwright.webview2.config.ts expects ChatClaw to be running
# with CDP enabled. Run tests with:
#   pnpm playwright test --config playwright.webview2.config.ts
#
# Enable WebView2 CDP mode for Playwright tests (set to 1 to enable)
WEBVIEW2_CDP_ENABLED=0

WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=--remote-debugging-port=9222
